{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace=@commonality/sdk",
    "dev": "../node_modules/.bin/vite",
    "pretypecheck": "npm run build --workspace=@commonality/sdk",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run build --workspace=@commonality/sdk",
    "build": "tsc -b && ../node_modules/.bin/vite build",
    "build:ipfs": "tsc -b && ../node_modules/.bin/vite build --mode ipfs",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "preview": "../node_modules/.bin/vite preview"
  },
  "dependencies": {
    "@commonality/sdk": "file:../sdk",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.5",
    "@mui/material": "^7.3.5",
    "@tanstack/react-query": "^5.90.11",
    "connectkit": "^1.9.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.0",
    "rehype-sanitize": "^6.0.0",
    "viem": "^2.40.3",
    "wagmi": "^3.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "events": "^3.3.0",
    "globals": "^16.5.0",
    "jsdom": "^27.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "7.2.4",
    "vitest": "^3.2.4"
  }
}
