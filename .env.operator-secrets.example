# Commonality operator-only secrets
#
# Copy to ~/.secrets/commonality/operator.env (or set
# COMMONALITY_OPERATOR_SECRETS_FILE to another path). Keep this outside the repo
# tree. These secrets are for maintenance/setup scripts, not deployed services.

DEPLOYER_PRIVATE_KEY=0x_your_deployer_wallet_private_key
ENS_OWNER_PRIVATE_KEY=0x_private_key_of_ens_name_owner

# IPFS/IPNS/ENS deployment
PINATA_JWT=your_pinata_jwt_token
# IPNS_PRIVATE_KEY_TESTNET_COMMONALITY=base64_encoded_w3name_private_key
# IPNS_PRIVATE_KEY_TESTNET_LAZYGIVING=...
# IPNS_PRIVATE_KEY_TESTNET_ALIGNMENT=...
# IPNS_PRIVATE_KEY_TESTNET_TALLY=...
# IPNS_PRIVATE_KEY_TESTNET_CONTENT_FUNDING=...
# IPNS_PRIVATE_KEY_TESTNET_CIVILITY=...
# IPNS_PRIVATE_KEY_TESTNET_COMMON_SENSE_MAJORITY=...
# IPNS_PRIVATE_KEY_TESTNET_CONCEPTSPACE=...
# IPNS_PRIVATE_KEY_TESTNET_UBER_UI=...

# Optional DNS automation. Token only needs DNS edit access for the dnsRoot in
# deployments/testnet-names.json (currently commonality.works).
# CLOUDFLARE_API_TOKEN=your_cloudflare_dns_edit_token
# CLOUDFLARE_ZONE_ID=your_dns_root_zone_id

# Optional script/API account automation
# RENDER_API_KEY=your_render_api_key
