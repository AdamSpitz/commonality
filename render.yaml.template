      - key: COINBASE_CDP_API_KEY_ID
        sync: false  # Secret: Coinbase Onramp session-token API key id
      - key: COINBASE_CDP_API_KEY_SECRET
        sync: false  # Secret: Coinbase Onramp session-token private key
      - key: CHANNEL_REGISTRY_ADDRESS
        sync: false  # from-env: CHANNEL_REGISTRY_ADDRESS
      - key: CHANNEL_VERIFIER_ADDRESS
        sync: false  # from-env: CHANNEL_VERIFIER_ADDRESS
      - key: CREATOR_GAS_TANK_ADDRESS
        sync: false  # from-env: CREATOR_GAS_TANK_ADDRESS
      - key: CHAIN_ID
        value: 84532
      - key: SUBMIT_VERIFICATION_TX
        value: "false"
    healthCheckPath: /health
    autoDeploy: true
    plan: standard

