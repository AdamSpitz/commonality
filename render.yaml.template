# Render deployment configuration for Commonality services
# See https://render.com/docs/blueprint-spec
#
# THIS FILE IS A TEMPLATE. Generate render.yaml by running:
#   node scripts/generate-render-yaml.mjs [path/to/deployment.env]
# Default env file: deployments/base-sepolia.env

databases:
  - name: commonality-indexer-db
    plan: basic-256mb
    postgresMajorVersion: 16

services:
  # Indexer
  - type: web
    name: commonality-indexer
    env: docker
    rootDir: indexer
    dockerContext: .
    dockerfilePath: Dockerfile
    envVars:
      - key: NODE_ENV
        value: production
      - key: PONDER_SCRIPT
        value: start
      - key: DATABASE_URL
        fromDatabase:
          name: commonality-indexer-db
          property: connectionString
      - key: DATABASE_SCHEMA
        value: commonality_base_sepolia_v5
      - key: PONDER_EXPERIMENTAL_DB
        value: platform
      - key: PONDER_CHAIN
        sync: false  # Set in Render dashboard: base-sepolia or mainnet
      - key: PONDER_RPC_URL_84532
        sync: false  # Secret: RPC provider URL (contains API key)
      - key: PONDER_RPC_URL_1
        sync: false  # Secret: RPC provider URL (contains API key)
      - key: PONDER_ETH_GET_LOGS_BLOCK_RANGE
        value: 1000
      - key: START_BLOCK
        sync: false  # from-env: START_BLOCK
      - key: BELIEFS_CONTRACT_ADDRESS
        sync: false  # from-env: BELIEFS_CONTRACT_ADDRESS
      - key: IMPLICATIONS_CONTRACT_ADDRESS
        sync: false  # from-env: IMPLICATIONS_CONTRACT_ADDRESS
      - key: ACCOUNT_ASSERTIONS_ADDRESS
        sync: false  # from-env: ACCOUNT_ASSERTIONS_ADDRESS
      - key: ASSURANCE_CONTRACT_FACTORY_ADDRESS
        sync: false  # from-env: ASSURANCE_CONTRACT_FACTORY_ADDRESS
      - key: ERC1155_FACTORY_ADDRESS
        sync: false  # from-env: ERC1155_FACTORY_ADDRESS
      - key: MARKETPLACE_FACTORY_ADDRESS
        sync: false  # from-env: MARKETPLACE_FACTORY_ADDRESS
      - key: DELEGATABLE_NOTES_ADDRESS
        sync: false  # from-env: DELEGATABLE_NOTES_ADDRESS
      - key: RECURRING_PLEDGES_ADDRESS
        sync: false  # from-env: RECURRING_PLEDGES_ADDRESS
      - key: NOTE_INTENT_ADDRESS
        sync: false  # from-env: NOTE_INTENT_ADDRESS
      - key: ALIGNMENT_ATTESTATIONS_ADDRESS
        sync: false  # from-env: ALIGNMENT_ATTESTATIONS_ADDRESS
      - key: MUTABLE_REF_UPDATER_ADDRESS
        sync: false  # from-env: MUTABLE_REF_UPDATER_ADDRESS
      - key: NUDGE_PUBLICATIONS_CONTRACT_ADDRESS
        sync: false  # from-env: NUDGE_PUBLICATIONS_CONTRACT_ADDRESS
      - key: PUBLISHED_DATA_CONTRACT_ADDRESS
        sync: false  # from-env: PUBLISHED_DATA_CONTRACT_ADDRESS
      - key: PUBLISHED_DATA_START_BLOCK
        sync: false  # from-env: PUBLISHED_DATA_START_BLOCK
      - key: CONTENT_REGISTRY_ADDRESS
        sync: false  # from-env: CONTENT_REGISTRY_ADDRESS
      - key: CHANNEL_REGISTRY_ADDRESS
        sync: false  # from-env: CHANNEL_REGISTRY_ADDRESS
      - key: CHANNEL_ESCROW_ADDRESS
        sync: false  # from-env: CHANNEL_ESCROW_ADDRESS
      - key: CREATOR_CONTRACT_FACTORY_ADDRESS
        sync: false  # from-env: CREATOR_CONTRACT_FACTORY_ADDRESS
    healthCheckPath: /graphql
    # Intentional Render workaround: this disk is not used for indexer app state.
    # Render disables zero-downtime/rolling deploys for services with persistent
    # disks. Ponder needs that stop-before-start behavior because `ponder start`
    # takes an exclusive lock on DATABASE_SCHEMA. Do not remove this just because
    # /data looks unused; replace it only with another singleton deploy strategy.
    disk:
      name: commonality-indexer-data
      mountPath: /data
      sizeGB: 1
    autoDeploy: true
    plan: standard

  # Bundled AI service host (Bundle A — Attesters)
  - type: web
    name: commonality-service-host-attesters
    env: docker
    rootDir: .
    dockerContext: .
    dockerfilePath: service-host/Dockerfile
    envVars:
      - key: NODE_ENV
        value: production
      - key: SERVICE_HOST_PORT
        value: 3000
      - key: ETHEREUM_RPC_URL
        sync: false  # Secret: RPC provider URL (contains API key)
      - key: OPENROUTER_API_KEY
        sync: false  # Secret
      - key: OPENROUTER_MODEL
        value: anthropic/claude-3.5-haiku
      - key: IPFS_API
        value: https://ipfs.io/api/v0
      - key: IPFS_GATEWAY
        value: https://ipfs.io/ipfs
      - key: IMPLICATION_ATTESTER_PRIVATE_KEY
        sync: false  # Secret
      - key: IMPLICATION_ATTESTER_PAYMENT_ADDRESS
        value: "${IMPLICATION_ATTESTER_PAYMENT_ADDRESS}"
      - key: IMPLICATION_ATTESTER_TRUSTED_FINDER_KEY
        sync: false  # Set in Render dashboard (generated by scripts/generate-wallets.mjs)
      - key: IMPLICATIONS_CONTRACT_ADDRESS
        sync: false  # from-env: IMPLICATIONS_CONTRACT_ADDRESS
      - key: CONTENT_ATTESTER_PRIVATE_KEY
        sync: false  # Secret
      - key: CONTENT_ATTESTER_PAYMENT_ADDRESS
        value: "${CONTENT_ATTESTER_PAYMENT_ADDRESS}"
      - key: CONTENT_ATTESTER_TRUSTED_FINDER_KEY
        sync: false  # Set in Render dashboard (generated by scripts/generate-wallets.mjs)
      - key: ALIGNMENT_ATTESTATIONS_CONTRACT_ADDRESS
        sync: false  # from-env: ALIGNMENT_ATTESTATIONS_CONTRACT_ADDRESS
      - key: ALIGNMENT_TOPIC_STATEMENT_CID
        sync: false  # Set in Render dashboard after pinning topic statement to IPFS
      - key: CONTENT_ATTESTER_NAME
        value: "${CONTENT_ATTESTER_NAME}"
      - key: CONTENT_ATTESTER_PROMPT_TEMPLATE
        value: "${CONTENT_ATTESTER_PROMPT_TEMPLATE}"
      - key: BEAT_MEMORY_ENABLED
        value: "true"
      - key: BEAT_MEMORY_BEAT_ID
        value: us-politics
      - key: BEAT_MEMORY_PURPOSES
        value: civility_context,general_beat_context,source_management
      - key: BEAT_MEMORY_BEAT_DEFINITION_JSON
        value: "${BEAT_MEMORY_BEAT_DEFINITION_JSON}"
      - key: BEAT_MEMORY_INGESTION_STATE_FILE
        value: /data/beat-memory/us-politics.ingestion.json
      - key: BEAT_MEMORY_MEMORY_FILE
        value: /data/beat-memory/us-politics.memory.json
      - key: BEAT_MEMORY_METRICS_LOG_FILE
        value: /data/beat-memory/us-politics.metrics.jsonl
      - key: BEAT_MEMORY_WORKER_POLL_INTERVAL_MS
        value: 300000
      - key: BEAT_MEMORY_LLM_EXTRACTION_ENABLED
        value: "true"
      - key: BEAT_AGENT_ENABLED
        value: "true"
      - key: BEAT_AGENT_PRIVATE_KEY
        sync: false  # Secret
      - key: BEAT_AGENT_PAYMENT_ADDRESS
        value: "${BEAT_AGENT_PAYMENT_ADDRESS}"
      - key: BEAT_AGENT_TRUSTED_FINDER_KEY
        sync: false  # Set in Render dashboard (generated by scripts/generate-wallets.mjs)
      - key: BEAT_AGENT_BEAT_ID
        value: us-politics
      - key: BEAT_AGENT_NAME
        value: us-politics-civility
      - key: BEAT_AGENT_PROMPT_TEMPLATE
        value: "${BEAT_AGENT_PROMPT_TEMPLATE}"
      - key: BEAT_AGENT_INGESTION_STATE_FILE
        value: /data/beat-memory/us-politics.ingestion.json
      - key: BEAT_AGENT_MEMORY_FILE
        value: /data/beat-memory/us-politics.memory.json
      - key: BEAT_AGENT_EVALUATION_LOG_FILE
        value: /data/beat-agent/us-politics.evaluations.jsonl
      - key: BEAT_AGENT_METRICS_LOG_FILE
        value: /data/beat-agent/us-politics.metrics.jsonl
      - key: BEAT_AGENT_FINDER_ENABLED
        value: "false"
      - key: BEAT_AGENT_FINDER_STATE_FILE
        value: /data/beat-agent/us-politics.finder.json
      - key: BEAT_AGENT_FINDER_ATTESTER_URL
        value: https://commonality-service-host-attesters.onrender.com/beat-agent/evaluate-content
      - key: BEAT_AGENT_BEAT_KEYWORDS
        value: politics,policy,democrat,republican,liberal,conservative,bipartisan,civility,persuasion,good faith,common ground
      - key: BEAT_AGENT_PLATFORM_API_URL
        value: https://commonality-platform-api.onrender.com
      - key: BEAT_AGENT_MINIMUM_CONFIDENCE
        value: medium
      - key: BEAT_AGENT_ESTIMATED_INPUT_TOKENS
        value: 5000
      - key: BEAT_AGENT_ESTIMATED_OUTPUT_TOKENS
        value: 700
      - key: X_API_BEARER_TOKEN
        sync: false  # Secret
      - key: SERVICE_MARGIN_PERCENT
        value: 20
      - key: ETH_USD_PRICE
        value: 3000
      - key: GAS_PRICE_MULTIPLIER
        value: 1.2
      - key: IMPLICATION_ATTESTER_ESTIMATED_INPUT_TOKENS
        value: 1000
      - key: IMPLICATION_ATTESTER_ESTIMATED_OUTPUT_TOKENS
        value: 200
      - key: CONTENT_ATTESTER_ESTIMATED_INPUT_TOKENS
        value: 2500
      - key: CONTENT_ATTESTER_ESTIMATED_OUTPUT_TOKENS
        value: 400
      - key: RATE_LIMIT_WINDOW_MS
        value: 60000
      - key: RATE_LIMIT_MAX_REQUESTS
        value: 10
      - key: IMPLICATION_FINDER_ENABLED
        value: "false"
      - key: CONTENT_FINDER_ENABLED
        value: "false"
      - key: IMPLICATION_GRAPH_NUDGER_ENABLED
        value: "false"
      - key: BRIDGE_CREATOR_ENABLED
        value: "false"
      - key: EXPLORER_CURATOR_ENABLED
        value: "false"
    healthCheckPath: /health
    autoDeploy: true
    plan: standard
    disk:
      name: commonality-attester-data
      mountPath: /data
      sizeGB: 1

  # Platform API Service (content-funding channel resolution + content-attester queuing)
  - type: web
    name: commonality-platform-api
