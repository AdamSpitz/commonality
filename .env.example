# Commonality Environment Configuration
#
# This file is a REFERENCE showing all variables. Do NOT copy this to .env directly.
#
# Instead, use the two-file approach:
#
#   1. Copy .env.secrets.example -> .env.secrets   (your private keys & API keys)
#   2. Contract addresses live in deployments/<network>.env (auto-populated by deploy script)
#   3. Run: ./scripts/setup-env.sh <network>        (generates .env from the above)
#
# For local dev with Docker Compose, just run: docker-compose up
# (uses addresses from deployments/localhost.env automatically)

# =============================================================================
# Secrets (set in .env.secrets — never commit!)
# =============================================================================
# DEPLOYER_PRIVATE_KEY=0x...
# ATTESTER_PRIVATE_KEY=0x...
# OPENROUTER_API_KEY=sk-...
# ETHERSCAN_API_KEY=...
# VITE_WALLETCONNECT_PROJECT_ID=...

# =============================================================================
# Network RPC URLs (defaults work, but Alchemy/Infura are more reliable)
# =============================================================================
SEPOLIA_RPC_URL=https://rpc.sepolia.org
MAINNET_RPC_URL=https://eth.llamarpc.com

# =============================================================================
# Contract Addresses (auto-populated — see deployments/<network>.env)
# =============================================================================
# BELIEFS_CONTRACT_ADDRESS=0x...
# IMPLICATIONS_CONTRACT_ADDRESS=0x...
# ALIGNMENT_ATTESTATIONS_CONTRACT_ADDRESS=0x...
# DELEGATABLE_NOTES_CONTRACT_ADDRESS=0x...
# MUTABLE_REF_UPDATER_CONTRACT_ADDRESS=0x...
# ASSURANCE_CONTRACT_FACTORY_ADDRESS=0x...
# ERC1155_FACTORY_ADDRESS=0x...
# MARKETPLACE_FACTORY_ADDRESS=0x...
# PUBSTARTER_ADDRESS=0x...

# =============================================================================
# Optional Configuration
# =============================================================================
IPFS_API=http://localhost:5001
IPFS_GATEWAY=http://localhost:8080/ipfs
NUM_USERS=10
NUM_ROUNDS=3
START_BLOCK=1
EVENT_CACHE_URL=http://localhost:42069
PLATFORM_API_URL=http://localhost:3001
# Local dev may leave this blank/false; testnet/mainnet UI config must set true.
VITE_ENABLE_CHANNEL_METADATA_LOOKUP=
