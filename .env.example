# Commonality Docker Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Deployment Configuration
# =============================================================================

# Private key for deployment (required for testnet/mainnet)
# IMPORTANT: Never commit the actual private key to git!
# For testnet/mainnet deployments, set this in your .env file (not .env.example)
# DEPLOYER_PRIVATE_KEY=0x...

# RPC URLs for external networks
SEPOLIA_RPC_URL=https://rpc.sepolia.org
MAINNET_RPC_URL=https://eth.llamarpc.com

# =============================================================================
# Simulation Configuration
# =============================================================================

# Number of simulated users to generate (default: 30)
NUM_USERS=30

# Number of simulation rounds to run (default: 5)
# Each round executes random actions by users (signing statements, creating implications, etc.)
NUM_ROUNDS=5

# =============================================================================
# Contract Addresses (Auto-populated by init script)
# =============================================================================
# These will be automatically set by the docker-init.js script
# You don't need to set these manually when using Docker

BELIEFS_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
IMPLICATIONS_CONTRACT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
PROJECT_ALIGNMENT_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
DELEGATABLE_NOTES_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9
ASSURANCE_CONTRACT_FACTORY_ADDRESS=0x5FC8d32690cc91D4c39d9d3abcBD16989F875707
ERC1155_FACTORY_ADDRESS=0x0165878A594ca255338adfa4d48449f69242Eb8F
MARKETPLACE_FACTORY_ADDRESS=0xa513E6E4b8f2a923D98304ec87F64353C4D5C853

# =============================================================================
# Advanced Configuration (Optional)
# =============================================================================

# Ponder port (default: 42069)
# PONDER_PORT=42069

# Hardhat node port (default: 8545)
# HARDHAT_PORT=8545

# IPFS configuration
# Note: These are set automatically in docker-compose.yml for the indexer
# Set these for integration tests running on the host
IPFS_API=http://localhost:5001
IPFS_GATEWAY=http://localhost:8080/ipfs
NUM_USERS=10
NUM_ROUNDS=3

PUBSTARTER_ADDRESS=0x2279B7A0a67DB372996a5FaB50D91eAA73d2eBe6
START_BLOCK=1
PROJECT_ALIGNMENT_CONTRACT_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
DELEGATABLE_NOTES_CONTRACT_ADDRESS=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9
MUTABLE_REF_UPDATER_CONTRACT_ADDRESS=0xDc64a140Aa3E981100a9becA4E685f962f0cF6C9
