# Commonality Environment Configuration
#
# This file is a reference. Do not copy it to .env directly.
#
# Non-local deployment flow:
#   1. node scripts/generate-wallets.mjs
#      - writes private keys/finder secrets to .env.secrets
#      - writes public operational addresses + UI trust defaults to deployments/operator-addresses.env
#   2. Fill the remaining external-service values in .env.secrets.
#   3. Deploy contracts; hardhat automatically reads .env.secrets and deployments/operator-addresses.env.
#   4. ./scripts/setup-env.sh <network>
#      - combines .env.secrets + deployments/operator-addresses.env + deployments/<network>.env
#        into .env, ui/.env, and service env files.
#
# Local dev should use ./scripts/services.sh --start (not raw docker compose),
# followed by ./scripts/data.sh --seed or ./scripts/data.sh --seed=demo.

# =============================================================================
# Generated private secrets (set in .env.secrets — never commit)
# =============================================================================
# DEPLOYER_PRIVATE_KEY=0x...
# ENS_OWNER_PRIVATE_KEY=0x...
# IMPLICATION_ATTESTER_PRIVATE_KEY=0x...
# CONTENT_ATTESTER_PRIVATE_KEY=0x...
# VERIFIER_PRIVATE_KEY=0x...
# IMPLICATION_GRAPH_NUDGER_PRIVATE_KEY=0x...
# BRIDGE_CREATOR_PRIVATE_KEY=0x...
# EXPLORER_CURATOR_PRIVATE_KEY=0x...
# IMPLICATION_ATTESTER_TRUSTED_FINDER_KEY=...
# IMPLICATION_FINDER_ATTESTER_FINDER_KEY=...
# CONTENT_ATTESTER_TRUSTED_FINDER_KEY=...
# CONTENT_FINDER_ATTESTER_FINDER_KEY=...

# =============================================================================
# Generated public operational addresses (deployments/operator-addresses.env)
# =============================================================================
# DEPLOYER_ADDRESS=0x...
# CONTRACT_ADMIN_ADDRESS=0x...  # separate cold/admin account; non-local deploys require this
# ENS_OWNER_ADDRESS=0x...
# IMPLICATION_ATTESTER_ADDRESS=0x...
# CONTENT_ATTESTER_ADDRESS=0x...
# CHANNEL_VERIFIER_TRUSTED_SIGNER_ADDRESS=0x...
# IMPLICATION_GRAPH_NUDGER_ADDRESS=0x...
# BRIDGE_CREATOR_ADDRESS=0x...
# EXPLORER_CURATOR_ADDRESS=0x...
# IMPLICATION_ATTESTER_PAYMENT_ADDRESS=0x...
# CONTENT_ATTESTER_PAYMENT_ADDRESS=0x...
# VITE_DEFAULT_TRUSTED_ATTESTERS=0x...
# VITE_DEFAULT_TRUSTED_CONTENT_ATTESTERS=0x...
# VITE_NONINFLAMMATORY_TOPIC_CID=bafy...
# VITE_DEFAULT_NUDGERS=[{"address":"0x...","name":"..."}]
# VITE_CSM_MEDIATOR_NUDGER={"address":"0x...","name":"Common Sense Majority mediator"}

# =============================================================================
# External services (set in .env.secrets)
# =============================================================================
# OPENROUTER_API_KEY=sk-...
# VITE_WALLETCONNECT_PROJECT_ID=...
# PINATA_JWT=...
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
MAINNET_RPC_URL=https://eth.llamarpc.com
# Deployed indexer/event-cache base URL used by IPFS UI builds.
# EVENT_CACHE_URL=https://commonality-indexer.onrender.com

# =============================================================================
# Contract addresses (auto-populated by hardhat into deployments/<network>.env)
# =============================================================================
# BELIEFS_CONTRACT_ADDRESS=0x...
# IMPLICATIONS_CONTRACT_ADDRESS=0x...
# ALIGNMENT_ATTESTATIONS_CONTRACT_ADDRESS=0x...
# DELEGATABLE_NOTES_CONTRACT_ADDRESS=0x...
# MUTABLE_REF_UPDATER_CONTRACT_ADDRESS=0x...
# ASSURANCE_CONTRACT_FACTORY_ADDRESS=0x...
# ERC1155_FACTORY_ADDRESS=0x...
# MARKETPLACE_FACTORY_ADDRESS=0x...
# PROJECT_FACTORY_ADDRESS=0x...
# CHANNEL_VERIFIER_ADDRESS=0x...
# CONTENT_REGISTRY_ADDRESS=0x...
# CHANNEL_REGISTRY_ADDRESS=0x...
# CHANNEL_ESCROW_ADDRESS=0x...
# CREATOR_CONTRACT_FACTORY_ADDRESS=0x...
# NUDGE_PUBLICATIONS_CONTRACT_ADDRESS=0x...

# =============================================================================
# Public UI naming (optional; scripts/setup-env.sh derives per-domain URLs,
# CORS_ALLOWED_ORIGINS, and CLAIM_PAGE_BASE_URL from these)
# =============================================================================
# UI_PUBLIC_ROOT_DOMAIN=commonality.works
# UI_PUBLIC_ENVIRONMENT_LABEL=testnet
# UI_PUBLIC_URL_SCHEME=https
# UI_CORS_EXTRA_ROOT_DOMAINS=commonality.eth.limo

# =============================================================================
# Optional/default local configuration
# =============================================================================
IPFS_API=http://localhost:5001
IPFS_GATEWAY=http://localhost:8080/ipfs
EVENT_CACHE_URL=http://localhost:42069
PLATFORM_API_URL=http://localhost:3001
NUM_USERS=10
NUM_ROUNDS=3

# =============================================================================
# Verifier guarded local-stack opt-ins (optional)
# =============================================================================
# These authorize the guarded verifier checks to actually run against the local
# Dockerized dev stack (they may wipe/restart services, mine blocks, or drive an
# E2E browser journey). They are per-environment "is it okay to mess with the
# local setup?" flags, not secrets — local dev data is ephemeral by policy, so
# it's fine to leave them on for local dev.
#
# Recommended: set these in .envrc (already gitignored) so direnv auto-loads
# them into every shell, rather than .env. They're listed here only so they're
# discoverable. See workflow/deployment.md and verifier/coverage/guarded-check-policy.json.
# COMMONALITY_VERIFIER_ALLOW_DESTRUCTIVE=1        # stack.fresh-seeded (wipes + reseeds local data)
# COMMONALITY_VERIFIER_ALLOW_RESTART=1            # stack.restart-consistency
# COMMONALITY_VERIFIER_ALLOW_E2E_STACK=1           # stack.user-journeys, artifact.ipfs-domain-smoke, operations.indexer-lag
# COMMONALITY_VERIFIER_ALLOW_STACK_GUARDED_FIXTURE=1  # known-bad.* verifier-of-verifier fixtures
