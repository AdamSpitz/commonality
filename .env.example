# Commonality Docker Environment Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Simulation Configuration
# =============================================================================

# Number of simulated users to generate (default: 30)
NUM_USERS=30

# Number of simulation rounds to run (default: 5)
# Each round executes random actions by users (signing statements, creating implications, etc.)
NUM_ROUNDS=5

# =============================================================================
# Contract Addresses (Auto-populated by init script)
# =============================================================================
# These will be automatically set by the docker-init.js script
# You don't need to set these manually when using Docker

BELIEFS_CONTRACT_ADDRESS=
IMPLICATIONS_CONTRACT_ADDRESS=
PROJECT_ALIGNMENT_ADDRESS=
DELEGATABLE_NOTES_ADDRESS=
ASSURANCE_CONTRACT_FACTORY_ADDRESS=
ERC1155_FACTORY_ADDRESS=
MARKETPLACE_FACTORY_ADDRESS=

# =============================================================================
# Advanced Configuration (Optional)
# =============================================================================

# Ponder port (default: 42069)
# PONDER_PORT=42069

# Hardhat node port (default: 8545)
# HARDHAT_PORT=8545
