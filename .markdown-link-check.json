{
  "replacementPatterns": [
    { "pattern": "^/docs/", "replacement": "{{BASEURL}}/docs/" },
    { "pattern": "^/workflow/", "replacement": "{{BASEURL}}/workflow/" },
    { "pattern": "^/ui/", "replacement": "{{BASEURL}}/ui/" },
    { "pattern": "^/specs/", "replacement": "{{BASEURL}}/specs/" }
