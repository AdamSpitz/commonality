{
  "name": "@commonality/sdk",
  "version": "1.0.0",
  "description": "SDK for interacting with Commonality smart contracts",
  "type": "module",
  "exports": {
    "./node": {
      "types": "./dist/src/config-node.d.ts",
      "default": "./dist/src/config-node.js"
    },
    "./machinery": {
      "types": "./dist/src/machinery.d.ts",
      "default": "./dist/src/machinery.js"
    },
    "./indexer-sync": {
      "types": "./dist/src/indexer-sync.d.ts",
      "default": "./dist/src/indexer-sync.js"
    },
    "./abis": {
      "types": "./dist/src/abis.d.ts",
      "default": "./dist/src/abis.js"
    },
    "./utils": {
      "types": "./dist/src/utils/index.d.ts",
      "default": "./dist/src/utils/index.js"
    },
    "./conceptspace": {
      "types": "./dist/src/subsystems/conceptspace/index.d.ts",
      "default": "./dist/src/subsystems/conceptspace/index.js"
    },
    "./content-funding": {
      "types": "./dist/src/subsystems/content-funding/index.d.ts",
      "default": "./dist/src/subsystems/content-funding/index.js"
    },
    "./delegation": {
      "types": "./dist/src/subsystems/delegation/index.d.ts",
      "default": "./dist/src/subsystems/delegation/index.js"
    },
    "./displayable-documents": {
      "types": "./dist/src/subsystems/displayable-documents/index.d.ts",
      "default": "./dist/src/subsystems/displayable-documents/index.js"
    },
    "./fundingportals": {
      "types": "./dist/src/subsystems/fundingportals/index.d.ts",
      "default": "./dist/src/subsystems/fundingportals/index.js"
    },
    "./identity": {
      "types": "./dist/src/subsystems/identity/index.d.ts",
      "default": "./dist/src/subsystems/identity/index.js"
    },
    "./lazy-giving": {
      "types": "./dist/src/subsystems/lazy-giving/index.d.ts",
      "default": "./dist/src/subsystems/lazy-giving/index.js"
    },
    "./mutable-refs": {
      "types": "./dist/src/subsystems/mutable-refs/index.d.ts",
      "default": "./dist/src/subsystems/mutable-refs/index.js"
    },
    "./nudger-publications": {
      "types": "./dist/src/subsystems/nudger-publications/index.d.ts",
      "default": "./dist/src/subsystems/nudger-publications/index.js"
    },
    "./signer-profiles": {
      "types": "./dist/src/subsystems/signer-profiles/index.d.ts",
      "default": "./dist/src/subsystems/signer-profiles/index.js"
    },
    "./subjectiv": {
      "types": "./dist/src/subsystems/subjectiv/index.d.ts",
      "default": "./dist/src/subsystems/subjectiv/index.js"
    }
  },
  "dependencies": {
    "viem": "^2.53.1"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "mocha",
    "lint": "eslint .",
    "sync-abis": "tsx scripts/sync-abis.ts",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "eslint": "^9.39.1",
    "mocha": "^10.8.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.46.4"
  }
}
