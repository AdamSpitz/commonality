{
  "name": "@commonality/sdk",
  "version": "1.0.0",
  "description": "SDK for interacting with Commonality smart contracts",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./node": {
      "types": "./dist/src/config-node.d.ts",
      "default": "./dist/src/config-node.js"
    }
  },
  "dependencies": {
    "viem": "^2.53.1"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "mocha",
    "lint": "eslint .",
    "sync-abis": "tsx scripts/sync-abis.ts",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "eslint": "^9.39.1",
    "mocha": "^10.8.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.46.4"
  }
}
