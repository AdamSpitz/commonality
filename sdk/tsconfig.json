{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "..",
    "strict": false,
    "declaration": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "noEmit": false,
    "types": ["node", "mocha"]
  },
  "include": ["src/**/*", "../abis/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "src/**/*.test.ts"]
}
