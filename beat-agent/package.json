{
  "name": "@commonality/beat-agent",
  "version": "0.1.0",
  "description": "Beat-aware content attester that consumes beat-memory ambient context",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build --workspace=@commonality/beat-memory",
    "test": "mocha",
    "lint": "eslint ."
  },
  "dependencies": {
    "@commonality/attester-core": "0.1.0",
    "@commonality/beat-memory": "0.1.0",
    "@commonality/finder-core": "0.1.0",
    "@commonality/sdk": "1.0.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "eslint": "^9.39.1",
    "mocha": "^10.8.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.46.4",
    "viem": "2.53.1"
  }
}
