# Commonality Secrets
# Copy to .env.secrets and fill in your values.
# NEVER commit .env.secrets to git!

# =============================================================================
# Deployment (required for testnet/mainnet contract deployment)
# =============================================================================
DEPLOYER_PRIVATE_KEY=0x_your_deployer_wallet_private_key

# =============================================================================
# Attester Service (required for running the AI attester)
# =============================================================================
ATTESTER_PRIVATE_KEY=0x_your_attester_wallet_private_key
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# =============================================================================
# UI (required for wallet connection)
# =============================================================================
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# =============================================================================
# UI Deployment (required for IPFS upload and ENS update)
# =============================================================================
PINATA_JWT=your_pinata_jwt_token
ENS_OWNER_PRIVATE_KEY=0x_private_key_of_ens_name_owner

# Required for testnet/mainnet UI builds. This must be the public base URL of
# the deployed indexer/event-cache service; it is baked into the IPFS bundle.
EVENT_CACHE_URL=https://your-indexer.example.com

# RPC URL for ENS contract calls (mainnet ENS, even when deploying testnet
# UIs — the ENS name lives on L1 regardless of which chain the dapp targets).
# Optional; falls back to a public endpoint if unset.
# MAINNET_RPC_URL=https://eth-mainnet.example.com

# -----------------------------------------------------------------------------
# IPNS keys (one per UI subdomain, base64-encoded w3name private key).
# Generate each with:  ./scripts/setup-ipns-key.sh
# After generating, set the ENS contenthash and DNSLink TXT once; thereafter
# `./scripts/publish-ipns.sh <env-var> <cid>` updates the deployed build with
# no on-chain transaction and no DNS change.
# -----------------------------------------------------------------------------
# IPNS_PRIVATE_KEY_TESTNET_COMMONALITY=base64_encoded_w3name_private_key
# IPNS_PRIVATE_KEY_TESTNET_PUBSTARTER=...
# IPNS_PRIVATE_KEY_TESTNET_ALIGNMENT=...
# IPNS_PRIVATE_KEY_TESTNET_TALLY=...
# IPNS_PRIVATE_KEY_TESTNET_CONTENT_FUNDING=...
# IPNS_PRIVATE_KEY_TESTNET_NONINFLAMMATORY=...
# IPNS_PRIVATE_KEY_TESTNET_CSM=...
# IPNS_PRIVATE_KEY_TESTNET_CONCEPTSPACE=...

# =============================================================================
# Optional
# =============================================================================
# ETHERSCAN_API_KEY=your_etherscan_api_key
# PLATFORM_API_URL=https://your-platform-api.example.com
# Required for testnet/mainnet UI builds so creator/channel names can resolve
# through the deployed platform API instead of silently falling back to IDs.
# VITE_ENABLE_CHANNEL_METADATA_LOOKUP=true
# X402_PAYMENT_ADDRESS=0x_your_payment_recipient_address
