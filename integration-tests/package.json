  },
  "dependencies": {
    "@commonality/sdk": "*"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.10.0",
    "dotenv": "^17.2.3",
    "mocha": "^10.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2"
  }
}
