{
  "name": "commonality-integration-tests",
  "version": "1.0.0",
  "description": "Integration tests for Commonality",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "mocha",
    "test:verbose": "VERBOSE_TESTS=true mocha --reporter spec",
    "test:watch": "mocha --watch 'src/**/*.test.ts'",
