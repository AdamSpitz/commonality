{
  "name": "fake-data-generation",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "gen:users": "tsx generateUsers.ts",
    "gen:statements": "tsx generateStatements.ts",
    "gen:attesters": "tsx generateAttesters.ts",
    "gen:attestations": "tsx generateAttestations.ts",
    "gen:simulate": "tsx runSimulation.ts",
    "gen:small": "tsx runSimulation.ts 10 3",
    "gen:medium": "tsx runSimulation.ts 50 5",
    "gen:large": "tsx runSimulation.ts 100 10",
    "gen:clean": "rm -f users.json statements.json actions.json metrics.json",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "lint": "eslint ."
  },
  "dependencies": {
    "@commonality/sdk": "file:../sdk",
    "dotenv": "^16.4.0",
    "viem": "^2.21.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ethers": "^6.15.0",
    "hardhat": "^2.27.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.46.4"
  }
}
