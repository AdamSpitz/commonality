{
  "name": "fake-data-generation",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "gen:users": "tsx generateUsers.ts",
    "gen:statements": "tsx generateStatements.ts",
    "gen:seed:universe": "tsx generateSeedUniverse.ts",
    "gen:seed:markdown": "tsx generateSeedMarkdown.ts",
    "gen:seed:statements": "tsx prepareSeedStatements.ts",
    "gen:seed:upload": "tsx prepareSeedStatements.ts --upload",
    "gen:seed:implications": "tsx generateSeedImplicationEvaluations.ts",
    "gen:seed:implications:verify": "tsx verifySeedImplicationEvaluations.ts",
    "gen:seed:worker-outputs": "tsx generateSeedWorkerOutputs.ts",
    "test:seed:worker-outputs": "tsx generateSeedWorkerOutputs.ts --verify",
    "test:seed:implication-regression": "tsx verifySeedImplicationEvaluations.ts",
    "gen:proliferation": "tsx generateProliferation.ts",
    "gen:attesters": "tsx generateAttesters.ts",
    "gen:attestations": "tsx generateAttestations.ts",
    "gen:simulate": "tsx runSimulation.ts",
    "gen:tiny": "tsx runSimulation.ts 5 1 --statement-limit=12 --max-actions-per-user=2 --skip-invariants",
    "gen:small": "tsx runSimulation.ts 10 3",
    "gen:seed:local": "npm run gen:seed:universe -- --exclude-proliferation && tsx runSimulation.ts 10 3 --universe=output/seed-universe.json --publish-seed-worker-outputs",
    "gen:medium": "tsx runSimulation.ts 50 5",
    "gen:large": "tsx runSimulation.ts 100 10",
    "gen:clean": "rm -f data/users.json data/statements.json output/actions.json output/metrics.json",
    "test": "tsx --test test/*.test.ts",
    "pretypecheck": "npm run build --workspace=@commonality/implication-attester",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run build --workspace=@commonality/implication-attester",
    "build": "tsc",
    "clean": "rm -rf dist",
    "lint": "eslint ."
  },
  "dependencies": {
    "@commonality/implication-attester": "file:../implication-attester",
    "@commonality/sdk": "file:../sdk",
    "dotenv": "^16.4.0",
    "viem": "2.53.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ethers": "^6.15.0",
    "hardhat": "^2.27.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2",
    "typescript-eslint": "^8.46.4"
  }
}
