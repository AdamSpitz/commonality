{
  "id": "review.page-mobile-usability",
  "description": "Manual/cost-guarded LLM pass over a sample of the source-derived UI page inventory: does each page work well on mobile devices?",
  "cost": "llm",
  "trigger": {
    "type": "manual"
  },
  "retention": {
    "keep": 3,
    "keepDays": 30
  },
  "command": [
    "node",
    "checks/review/page-mobile-usability.mjs"
  ],
  "inputs": [
    {
      "kind": "params",
      "data": {
        "maxPages": 10,
        "maxFileChars": 25000,
        "taskKind": "clear-communication"
      }
    }
  ],
  "timeoutMs": 900000
}
