{
  "id": "review.workflow-clarity.common-sense-majority",
  "description": "Supervisor over the Common Sense Majority workflow-clarity leaves: was previously one wide LLM-judgment leaf spanning 4 domains, which was slow enough to time out. Split into an 'understand the movement' leaf and a 'complete an action' leaf so each runs faster and a timeout in one no longer blanks out the other's findings.",
  "trigger": {
    "type": "onInputChange",
    "debounceMinutes": 1
  },
  "retention": {
    "keep": 10,
    "keepDays": 90
  },
  "command": [
    "node",
    "checks/supervisor.mjs"
  ],
  "inputs": [
    {
      "kind": "check",
      "id": "review.workflow-clarity.common-sense-majority.understand",
      "role": "product-judgment"
    },
    {
      "kind": "check",
      "id": "review.workflow-clarity.common-sense-majority.act",
      "role": "product-judgment"
    },
    {
      "kind": "params",
      "data": {
        "label": "review.workflow-clarity.common-sense-majority",
        "rollup": {
          "type": "anyFail"
        },
        "freshness": {
          "requiredMaxAgeMinutes": 10080
        }
      }
    }
  ],
  "timeoutMs": 30000
}
