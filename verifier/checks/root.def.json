{
  "id": "root",
  "description": "Top-level Commonality verifier dashboard rollup.",
  "trigger": { "type": "manual" },
  "retention": { "keep": 10, "keepDays": 30 },
  "command": ["node", "checks/supervisor.mjs"],
  "inputs": [
    { "kind": "check", "id": "validation.pr", "role": "validation-pass" },
    { "kind": "check", "id": "validation.light-confidence", "role": "validation-pass" },
    { "kind": "check", "id": "validation.release-candidate", "role": "validation-pass" },
    { "kind": "check", "id": "validation.full-launch", "role": "validation-pass" },
    { "kind": "check", "id": "coverage.testing-plan", "role": "coverage" },
    { "kind": "check", "id": "staleness.known-gaps", "role": "coverage" },
    { "kind": "check", "id": "coverage.validation-roster", "role": "coverage" },
    { "kind": "check", "id": "coverage.domains", "role": "coverage" },
    { "kind": "check", "id": "meta.liveness", "role": "watchdog" },
    { "kind": "params", "data": { "label": "root", "rollup": { "type": "anyFail" } } }
  ],
  "timeoutMs": 30000
}
