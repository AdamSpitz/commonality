{
  "id": "validation.light-confidence",
  "description": "Light confidence validation rollup over PR validation and touched-surface manual/LLM attestations.",
  "trigger": { "type": "manual" },
  "retention": { "keep": 10, "keepDays": 30 },
  "command": ["node", "checks/supervisor.mjs"],
  "inputs": [
    { "kind": "check", "id": "validation.pr", "role": "pr-validation" },
    { "kind": "check", "id": "review.demo-dry-run", "role": "manual-attestation" },
    { "kind": "check", "id": "review.newcomer.touched-surface", "role": "manual-attestation" },
    { "kind": "check", "id": "review.real-ui.touched-domain", "role": "manual-attestation" },
    { "kind": "check", "id": "review.security.contracts", "role": "manual-attestation" },
    { "kind": "params", "data": { "label": "validation.light-confidence", "rollup": { "type": "anyFail" } } }
  ],
  "timeoutMs": 30000
}
