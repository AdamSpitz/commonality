{
  "id": "validation.full-launch",
  "description": "Full launch validation rollup over release-candidate confidence, configured testnet smoke, and final QA synthesis.",
  "trigger": { "type": "onInputChange", "debounceMinutes": 1 },
  "retention": { "keep": 10, "keepDays": 30 },
  "command": ["node", "checks/supervisor.mjs"],
  "inputs": [
    { "kind": "check", "id": "validation.release-candidate", "role": "release-candidate" },
    { "kind": "check", "id": "env.testnet-smoke", "role": "environment" },
    { "kind": "check", "id": "review.qa-synthesis.full-launch", "role": "qa-synthesis" },
    { "kind": "params", "data": { "label": "validation.full-launch", "rollup": { "type": "anyFail" } } }
  ],
  "timeoutMs": 30000
}
