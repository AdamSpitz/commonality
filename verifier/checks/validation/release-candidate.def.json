{
  "id": "validation.release-candidate",
  "description": "Release-candidate/testnet-ready validation rollup over full suite, deployable-artifact/local-stack checks, and QA synthesis.",
  "trigger": { "type": "onInputChange", "debounceMinutes": 1 },
  "retention": { "keep": 10, "keepDays": 30 },
  "command": ["node", "checks/supervisor.mjs"],
  "inputs": [
    { "kind": "check", "id": "automated.test-full", "role": "full-suite" },
    { "kind": "check", "id": "artifact.ipfs-domain-smoke", "role": "deployable-artifact" },
    { "kind": "check", "id": "stack.fresh-seeded", "role": "local-stack" },
    { "kind": "check", "id": "stack.restart-consistency", "role": "local-stack" },
    { "kind": "check", "id": "review.qa-synthesis.release-candidate", "role": "qa-synthesis" },
    { "kind": "params", "data": { "label": "validation.release-candidate", "rollup": { "type": "anyFail" } } }
  ],
  "timeoutMs": 30000
}
