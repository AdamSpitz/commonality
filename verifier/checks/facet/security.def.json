{
  "id": "facet.security",
  "description": "Concern facet: is the on-chain/security surface sound? Hardhat contract tests, focused security invariant/regression tests, smart-contract security review attestation, deterministic Slither static analysis, dependency audit, and deployed-contract smoke.",
  "trigger": {
    "type": "onInputChange",
    "debounceMinutes": 1
  },
  "retention": {
    "keep": 10,
    "keepDays": 30
  },
  "command": [
    "node",
    "checks/supervisor.mjs"
  ],
  "inputs": [
    {
      "kind": "check",
      "id": "automated.hardhat-contracts",
      "role": "automated"
    },
    {
      "kind": "check",
      "id": "review.security.contracts",
      "role": "manual-attestation"
    },
    {
      "kind": "check",
      "id": "review.security.slither",
      "role": "automated"
    },
    {
      "kind": "check",
      "id": "security.contract-invariants",
      "role": "automated"
    },
    {
      "kind": "check",
      "id": "testnet.contracts",
      "role": "deployed-contracts"
    },
    {
      "kind": "check",
      "id": "testnet.sponsored-gas",
      "role": "deployed-contracts"
    },
    {
      "kind": "check",
      "id": "testnet.sponsored-gas-abuse",
      "role": "deployed-contracts"
    },
    {
      "kind": "check",
      "id": "security.trust-roots",
      "role": "gating"
    },
    {
      "kind": "check",
      "id": "security.onchain-owners",
      "role": "gating"
    },
    {
      "kind": "check",
      "id": "security.package-lock-dependencies",
      "role": "gating"
    },
    {
      "kind": "check",
      "id": "automated.dependency-audit",
      "role": "gating"
    },
    {
      "kind": "check",
      "id": "security.agent-wallet-activity",
      "role": "advisory"
    },
    {
      "kind": "params",
      "data": {
        "label": "facet.security",
        "rollup": {
          "type": "anyFail"
        },
        "freshness": {
          "requiredMaxAgeMinutes": 10080
        }
      }
    }
  ],
  "timeoutMs": 30000
}
