{
  "id": "facet.security",
  "description": "Concern facet: is the on-chain/security surface sound? Smart-contract security review attestation.",
  "trigger": { "type": "manual" },
  "retention": { "keep": 10, "keepDays": 30 },
  "command": ["node", "checks/supervisor.mjs"],
  "inputs": [
    { "kind": "check", "id": "review.security.contracts", "role": "manual-attestation" },
    {
      "kind": "params",
      "data": {
        "label": "facet.security",
        "rollup": { "type": "anyFail" }
      }
    }
  ],
  "timeoutMs": 30000
}
