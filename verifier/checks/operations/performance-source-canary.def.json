{
  "id": "operations.performance-source-canary",
  "description": "Cheap static UI source performance canary: catches oversized source files and synchronous localStorage/sessionStorage access in page/component render paths before they become obvious bundle/timing/render regressions.",
  "trigger": {
    "type": "manual"
  },
  "retention": {
    "keep": 5,
    "keepDays": 30
  },
  "command": [
    "node",
    "checks/operations/performance-source-canary.mjs"
  ],
  "inputs": [
    {
      "kind": "params",
      "data": {
        "sourceDir": "ui/src",
        "maxSourceBytes": 180000,
        "allowLargeFiles": [],
        "allowSynchronousStorageFiles": []
      }
    }
  ],
  "timeoutMs": 30000,
  "display": {
    "preferredArtifact": "performance-source-canary.md"
  }
}
