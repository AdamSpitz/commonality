{
  "id": "operations.performance-budget",
  "description": "Builds the UI domain artifacts and enforces a deterministic bundle-size budget as a cheap proxy for launch performance regressions.",
  "trigger": { "type": "manual" },
  "retention": { "keep": 5, "keepDays": 30 },
  "command": ["node", "checks/operations/performance-budget.mjs"],
  "inputs": [
    {
      "kind": "params",
      "data": {
        "buildCommand": ["npm", "run", "ui:build:domains"],
        "commandTimeoutMs": 240000,
        "distDir": "ui/dist",
        "budget": {
          "maxSingleJsBytes": 2000000,
          "maxJsBytesPerDomain": 8000000,
          "maxCssBytesPerDomain": 250000,
          "maxHtmlBytesPerDomain": 100000
        }
      }
    }
  ],
  "timeoutMs": 270000
}
