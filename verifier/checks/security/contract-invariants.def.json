{
  "id": "security.contract-invariants",
  "description": "Runs the security-focused Hardhat regression/property tests for access control, malicious receiver behavior, assurance-contract accounting invariants, and DelegatableNotes payment-note audit regressions as a separately visible security signal.",
  "trigger": {
    "type": "cron",
    "everyMinutes": 720
  },
  "retention": {
    "keep": 10,
    "keepDays": 30
  },
  "command": [
    "verifier-run-command"
  ],
  "inputs": [
    {
      "kind": "params",
      "data": {
        "label": "Contract security invariants",
        "cwd": "..",
        "command": [
          "npx",
          "--workspace=hardhat",
          "hardhat",
          "test",
          "test/SecurityRegression.test.js",
          "test/AssuranceContractProperties.test.js",
          "test/DelegatableNotes.audit.test.js"
        ],
        "commandTimeoutMs": 180000,
        "artifactOutputLimit": 12000,
        "findingOutputLimit": 3000
      }
    }
  ],
  "timeoutMs": 210000
}
