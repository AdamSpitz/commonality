{
  "id": "coverage.domains",
  "description": "Verify every current UI domain has an intentional smoke/review/docs coverage story.",
  "trigger": { "type": "cron", "everyMinutes": 720 },
  "retention": { "keep": 10, "keepDays": 30 },
  "command": ["node", "checks/coverage/domains.mjs"],
  "inputs": [
    { "kind": "file", "path": "coverage/domains.json", "as": "domainsInventory" },
    { "kind": "file", "path": "../specs/product/ui-domains.md", "as": "uiDomainsDoc" }
  ],
  "timeoutMs": 30000
}
