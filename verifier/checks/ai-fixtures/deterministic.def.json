{
  "id": "ai-fixtures.deterministic",
  "description": "Runs the deterministic fixture harnesses for AI-facing services (benign + prompt-injection inputs, untrusted-data wrapping, schema/confidence normalization, publication/personalization shape, curation/bridge prompt construction, platform API fixtures, finder candidates, and LLM-failure fallback) with no live model calls.",
  "trigger": { "type": "manual" },
  "retention": { "keep": 5, "keepDays": 30 },
  "command": ["node", "checks/ai-fixtures/deterministic.mjs"],
  "inputs": [
    {
      "kind": "params",
      "data": {
        "commandTimeoutMs": 120000,
        "findingOutputLimit": 2000,
        "suites": [
          { "label": "beat-agent contextual-attestation fixture harness", "cwd": "../beat-agent", "command": ["npm", "test"] },
          { "label": "bridge-creator bridge-statement fixture harness", "cwd": "../bridge-creator", "command": ["npm", "test"] },
          { "label": "content-attester fixture harness", "cwd": "../content-attester", "command": ["npm", "test"] },
          { "label": "content-finder queue fixture harness", "cwd": "../content-finder", "command": ["npm", "test"] },
          { "label": "implication-attester fixture harness", "cwd": "../implication-attester", "command": ["npm", "test"] },
          { "label": "implication-finder candidate fixture harness", "cwd": "../implication-finder", "command": ["npm", "test"] },
          { "label": "explorer-curator personalization fixture harness", "cwd": "../explorer-curator", "command": ["npm", "test"] },
          { "label": "platform-api-service fixture harness", "cwd": "../platform-api-service", "command": ["npm", "test"] }
        ]
      }
    }
  ],
  "timeoutMs": 180000
}
