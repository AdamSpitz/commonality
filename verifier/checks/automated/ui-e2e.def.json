{
  "id": "automated.ui-e2e",
  "description": "UI Playwright rollup split by journey area. Re-run only the failing shard while debugging.",
  "trigger": {
    "type": "manual"
  },
  "retention": {
    "keep": 3,
    "keepDays": 14
  },
  "command": [
    "node",
    "checks/supervisor.mjs"
  ],
  "inputs": [
    { "kind": "check", "id": "automated.ui-e2e-smoke", "role": "suite" },
    { "kind": "check", "id": "automated.ui-e2e-conceptspace", "role": "suite" },
    { "kind": "check", "id": "automated.ui-e2e-funding", "role": "suite" },
    {
      "kind": "params",
      "data": {
        "label": "automated.ui-e2e",
        "rollup": { "type": "anyFail" },
        "freshness": { "requiredMaxAgeMinutes": 10080 }
      }
    }
  ],
  "timeoutMs": 30000
}
