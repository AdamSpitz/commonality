{
  "id": "automated.test-full-integration",
  "description": "Run the full integration test suite (on-chain + indexer paths): npm run integration-tests:raw.",
  "trigger": {
    "type": "manual"
  },
  "retention": {
    "keep": 3,
    "keepDays": 14
  },
  "command": [
    "node",
    "checks/automated/run-command-check.mjs"
  ],
  "inputs": [
    {
      "kind": "params",
      "data": {
        "label": "npm run integration-tests:raw",
        "command": [
          "npm",
          "run",
          "integration-tests:raw"
        ],
        "commandTimeoutMs": 900000,
        "cwd": ".."
      }
    }
  ],
  "timeoutMs": 930000
}
