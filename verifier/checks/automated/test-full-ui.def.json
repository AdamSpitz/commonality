{
  "id": "automated.test-full-ui",
  "description": "UI test suite rollup: Vitest shards plus Playwright shards. Re-run only the failing sub-check to avoid repeating the whole suite.",
  "trigger": {
    "type": "manual"
  },
  "retention": {
    "keep": 3,
    "keepDays": 14
  },
  "command": [
    "node",
    "checks/supervisor.mjs"
  ],
  "inputs": [
    {
      "kind": "check",
      "id": "automated.ui-vitest",
      "role": "suite"
    },
    {
      "kind": "check",
      "id": "automated.ui-e2e",
      "role": "suite"
    },
    {
      "kind": "params",
      "data": {
        "label": "automated.test-full-ui",
        "rollup": {
          "type": "anyFail"
        },
        "freshness": {
          "requiredMaxAgeMinutes": 10080
        }
      }
    }
  ],
  "timeoutMs": 30000
}
