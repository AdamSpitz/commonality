{
  "id": "automated.test-full-ui",
  "description": "Run the UI test suite (Playwright + Vitest): npm run ui:test.",
  "trigger": {
    "type": "manual"
  },
  "retention": {
    "keep": 3,
    "keepDays": 14
  },
  "command": [
    "verifier-run-command"
  ],
  "inputs": [
    {
      "kind": "params",
      "data": {
        "label": "npm run ui:test",
        "command": [
          "npm",
          "run",
          "ui:test"
        ],
        "commandTimeoutMs": 900000,
        "cwd": ".."
      }
    }
  ],
  "timeoutMs": 930000
}
