{
  "id": "automated.ui-vitest-shared",
  "description": "Run UI Vitest shared component/hook/store/trust tests.",
  "trigger": {
    "type": "manual"
  },
  "retention": {
    "keep": 3,
    "keepDays": 14
  },
  "command": [
    "verifier-run-command"
  ],
  "inputs": [
    {
      "kind": "params",
      "data": {
        "label": "npm run test:vitest --workspace=ui -- src/shared",
        "command": [
          "npm",
          "run",
          "test:vitest",
          "--workspace=ui",
          "--",
          "src/shared"
        ],
        "commandTimeoutMs": 180000,
        "cwd": ".."
      }
    }
  ],
  "timeoutMs": 210000
}
