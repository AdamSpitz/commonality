{
  "id": "automated.build",
  "description": "Run the project build/typecheck feedback loop: npm run build:raw.",
  "trigger": {
    "type": "manual"
  },
  "retention": {
    "keep": 3,
    "keepDays": 14
  },
  "command": [
    "verifier-run-command"
  ],
  "inputs": [
    {
      "kind": "params",
      "data": {
        "label": "npm run build:raw",
        "command": [
          "npm",
          "run",
          "build:raw"
        ],
        "commandTimeoutMs": 900000,
        "cwd": ".."
      }
    }
  ],
  "timeoutMs": 930000
}
