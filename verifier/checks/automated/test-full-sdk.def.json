{
  "id": "automated.test-full-sdk",
  "description": "Run the SDK test suite: npm run sdk:test.",
  "trigger": { "type": "manual" },
  "retention": { "keep": 3, "keepDays": 14 },
  "command": ["node", "checks/automated/run-command-check.mjs"],
  "inputs": [
    { "kind": "params", "data": { "label": "npm run sdk:test", "command": ["npm", "run", "sdk:test"], "commandTimeoutMs": 300000 } }
  ],
  "timeoutMs": 330000
}
