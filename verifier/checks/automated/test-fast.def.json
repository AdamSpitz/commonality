{
  "id": "automated.test-fast",
  "description": "Run the fast automated suite: npm run test:fast.",
  "trigger": {
    "type": "manual"
  },
  "retention": {
    "keep": 3,
    "keepDays": 14
  },
  "command": [
    "verifier-run-command"
  ],
  "inputs": [
    {
      "kind": "params",
      "data": {
        "label": "npm run test:fast",
        "command": [
          "npm",
          "run",
          "test:fast"
        ],
        "commandTimeoutMs": 900000,
        "cwd": ".."
      }
    }
  ],
  "timeoutMs": 930000
}
