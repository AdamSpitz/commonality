{
  "id": "testnet.indexer",
  "description": "Guarded deployed testnet indexer check: GraphQL _meta responds and is not too far behind the configured RPC.",
  "trigger": { "type": "manual" },
  "retention": { "keep": 5, "keepDays": 30 },
  "command": ["node", "checks/testnet/indexer.mjs"],
  "inputs": [
    { "kind": "file", "path": "environments/testnet.json", "as": "testnetConfig" },
    { "kind": "params", "data": { "guardPolicy": "Requires COMMONALITY_VERIFIER_ENABLE_TESTNET_SMOKE=1 and COMMONALITY_TESTNET_RPC_URL." } }
  ],
  "timeoutMs": 60000
}
