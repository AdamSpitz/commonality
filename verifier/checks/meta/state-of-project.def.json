{
  "id": "meta.state-of-project",
  "description": "Standing narrative-synthesis leaf: reads the latest stored facet rollups and the finding-rich review/coverage leaves and asks a model to write one human-readable 'state of the project' report — what works, what is red vs. merely unverified, and the prioritized remaining work. Non-gating: it describes the dashboard, it does not gate it. Wired advisory under meta.verifier-health.",
  "trigger": { "type": "manual" },
  "retention": { "keep": 5, "keepDays": 90 },
  "command": ["node", "checks/meta/state-of-project.mjs"],
  "inputs": [
    { "kind": "check", "id": "facet.functionality", "role": "facet" },
    { "kind": "check", "id": "facet.docs", "role": "facet" },
    { "kind": "check", "id": "facet.product", "role": "facet" },
    { "kind": "check", "id": "facet.security", "role": "facet" },
    { "kind": "check", "id": "review.docs-coherence", "role": "product-judgment" },
    { "kind": "check", "id": "review.landing-compelling", "role": "product-judgment" },
    { "kind": "check", "id": "review.workflow-clarity", "role": "product-judgment" },
    { "kind": "check", "id": "review.security.contracts", "role": "security-judgment" },
    { "kind": "check", "id": "coverage.readiness", "role": "coverage" },
    { "kind": "check", "id": "validation.pr", "role": "functionality" },
    {
      "kind": "params",
      "data": {
        "commandTimeoutMs": 600000,
        "maxFindingsChars": 8000,
        "staleAfterMinutes": 1440,
        "taskKind": "clear-communication"
      }
    }
  ],
  "timeoutMs": 630000
}
