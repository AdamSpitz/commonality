{
  "id": "meta.verifier-health",
  "description": "Roll up verifier-of-verifier checks into one gating dashboard input for root: is the verifier itself trustworthy (watchdogs, flakiness, coverage gaps, known-bad fixtures still catching their bug class, meta LLM review)? Project-level narrative/advisory leaves (report-currency, backlog-reminder, and the report.md narrative) deliberately do NOT live here — they observe the project, not the verifier, and hang off the root apex instead.",
  "trigger": {
    "type": "onInputChange",
    "debounceMinutes": 5
  },
  "retention": {
    "keep": 10,
    "keepDays": 30
  },
  "command": [
    "node",
    "checks/supervisor.mjs"
  ],
  "inputs": [
    {
      "kind": "check",
      "id": "meta.liveness",
      "role": "watchdog"
    },
    {
      "kind": "check",
      "id": "meta.flakiness",
      "role": "trend"
    },
    {
      "kind": "check",
      "id": "coverage.testing-plan",
      "role": "coverage"
    },
    {
      "kind": "check",
      "id": "staleness.known-gaps",
      "role": "coverage"
    },
    {
      "kind": "check",
      "id": "coverage.validation-roster",
      "role": "coverage"
    },
    {
      "kind": "check",
      "id": "coverage.domains",
      "role": "coverage"
    },
    {
      "kind": "check",
      "id": "coverage.pages",
      "role": "coverage"
    },
    {
      "kind": "check",
      "id": "coverage.workflows",
      "role": "coverage"
    },
    {
      "kind": "check",
