      "role": "coverage"
    },
    {
      "kind": "check",
      "id": "coverage.guarded-check-policy",
      "role": "coverage"
    },
    {
      "kind": "check",
      "id": "review.docs-broken-refs",
      "role": "coverage"
    },
    {
      "kind": "check",
      "id": "known-bad.liveness",
      "role": "known-bad"
    },
    {
      "kind": "check",
      "id": "known-bad.flakiness",
