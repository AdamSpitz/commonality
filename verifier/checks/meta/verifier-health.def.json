{
  "id": "meta.verifier-health",
  "description": "Roll up verifier-of-verifier checks into one dashboard input for root.",
  "trigger": { "type": "onInputChange", "debounceMinutes": 5 },
  "retention": { "keep": 10, "keepDays": 30 },
  "command": ["node", "checks/meta/verifier-health.mjs"],
  "inputs": [
    { "kind": "check", "id": "meta.liveness", "role": "watchdog" },
    { "kind": "check", "id": "coverage.testing-plan", "role": "coverage" },
    { "kind": "check", "id": "staleness.known-gaps", "role": "coverage" },
    { "kind": "check", "id": "coverage.validation-roster", "role": "coverage" },
    { "kind": "check", "id": "coverage.domains", "role": "coverage" },
    { "kind": "check", "id": "coverage.readiness", "role": "coverage" },
    { "kind": "check", "id": "review.docs-broken-refs", "role": "coverage" },
    { "kind": "check", "id": "known-bad.testing-plan", "role": "known-bad" },
    { "kind": "check", "id": "known-bad.staleness-known-gaps", "role": "known-bad" },
    { "kind": "check", "id": "known-bad.report-attestation", "role": "known-bad" },
    { "kind": "check", "id": "known-bad.readiness", "role": "known-bad" },
    { "kind": "check", "id": "meta.llm-check-review", "role": "verifier-review" },
    { "kind": "check", "id": "meta.llm-to-automated-candidates", "role": "automation-candidates" }
  ],
  "timeoutMs": 30000
}
