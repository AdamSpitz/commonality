{
  "id": "functionality.deep-stack",
  "description": "Functionality subfacet: deployable artifacts, local end-to-end stack proofs, deployment-depth history, and testnet smoke. Intermediate rollup gives guarded/deep checks their own branch so a changed stack leaf refreshes through functionality.deep-stack, facet.functionality, and root.",
  "trigger": { "type": "onInputChange", "debounceMinutes": 1 },
  "retention": { "keep": 10, "keepDays": 30 },
  "command": ["node", "checks/supervisor.mjs"],
  "inputs": [
    { "kind": "check", "id": "artifact.ipfs-domain-smoke", "role": "deployable-artifact" },
    { "kind": "check", "id": "stack.user-journeys", "role": "end-to-end-roundtrip" },
    { "kind": "check", "id": "automated.integration-tests", "role": "integration-tests" },
    { "kind": "check", "id": "stack.fresh-seeded", "role": "local-stack" },
    { "kind": "check", "id": "stack.restart-consistency", "role": "local-stack" },
    { "kind": "check", "id": "stack.deployment-depth", "role": "deployment-depth" },
    { "kind": "check", "id": "testnet.environment", "role": "deployed-testnet" },
    {
      "kind": "params",
      "data": {
        "label": "functionality.deep-stack",
        "rollup": { "type": "anyFail" },
        "freshness": { "requiredMaxAgeMinutes": 10080 }
      }
    }
  ],
  "timeoutMs": 30000
}
