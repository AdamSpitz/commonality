{
  "id": "known-bad.testing-plan",
  "description": "Proves coverage.testing-plan rejects a synthetic inventory missing required mappings.",
  "trigger": { "type": "cron", "everyMinutes": 720 },
  "retention": { "keep": 5, "keepDays": 30 },
  "command": ["node", "checks/known-bad/expect-bad-result.mjs"],
  "inputs": [
    {
      "kind": "file",
      "path": "fixtures/known-bad/testing-plan-missing-item.json",
      "as": "testingPlanItems"
    },
    {
      "kind": "params",
      "data": {
        "label": "coverage.testing-plan known-bad fixture",
        "targetScript": "checks/coverage/testing-plan.mjs",
        "expectedStatuses": ["fail"]
      }
    }
  ],
  "timeoutMs": 30000
}
