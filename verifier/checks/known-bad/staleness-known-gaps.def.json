{
  "id": "known-bad.staleness-known-gaps",
  "description": "Proves staleness.known-gaps rejects a synthetic stale known-gap record.",
  "trigger": { "type": "cron", "everyMinutes": 720 },
  "retention": { "keep": 5, "keepDays": 30 },
  "command": ["node", "checks/known-bad/expect-bad-result.mjs"],
  "inputs": [
    {
      "kind": "file",
      "path": "fixtures/known-bad/stale-known-gap.json",
      "as": "testingPlanItems"
    },
    {
      "kind": "params",
      "data": {
        "label": "staleness.known-gaps known-bad fixture",
        "targetScript": "checks/coverage/staleness-known-gaps.mjs",
        "expectedStatuses": ["fail"]
      }
    }
  ],
  "timeoutMs": 30000
}
