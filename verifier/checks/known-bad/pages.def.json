{
  "id": "known-bad.pages",
  "description": "Proves coverage.pages rejects a broken domain overlay: one that omits real domains the on-the-fly page inventory derives from source, and includes a phantom domain absent from source.",
  "trigger": { "type": "cron", "everyMinutes": 720 },
  "retention": { "keep": 5, "keepDays": 30 },
  "command": ["node", "checks/known-bad/expect-bad-result.mjs"],
  "inputs": [
    {
      "kind": "file",
      "path": "fixtures/known-bad/pages-overlay-broken.json",
      "as": "domainsInventory"
    },
    {
      "kind": "params",
      "data": {
        "label": "coverage.pages known-bad overlay fixture",
        "targetScript": "checks/coverage/pages.mjs",
        "expectedStatuses": ["fail"]
      }
    }
  ],
  "timeoutMs": 30000
}
