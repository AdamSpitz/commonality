{
  "id": "known-bad.state-of-project",
  "description": "Proves meta.state-of-project rejects bad synthesis-model output (non-JSON prose, and JSON missing the required reportMarkdown) with an error status instead of crashing or emitting a hollow report.",
  "trigger": { "type": "cron", "everyMinutes": 720 },
  "retention": { "keep": 5, "keepDays": 30 },
  "command": ["node", "checks/known-bad/expect-bad-result.mjs"],
  "inputs": [
    {
      "kind": "params",
      "data": {
        "label": "meta.state-of-project known-bad",
        "targetScript": "checks/meta/state-of-project.mjs",
        "expectedStatuses": ["error"],
        "targetInputs": [
          { "kind": "check", "id": "facet.functionality", "role": "facet" }
        ],
        "cases": [
          {
            "label": "non-JSON prose response",
            "extraEnv": { "COMMONALITY_VERIFIER_STATE_OF_PROJECT_FIXTURE_RESPONSE": "Sorry, I cannot produce a report right now." }
          },
          {
            "label": "JSON missing reportMarkdown",
            "extraEnv": { "COMMONALITY_VERIFIER_STATE_OF_PROJECT_FIXTURE_RESPONSE": "{\"status\":\"pass\",\"summary\":\"all good\"}" }
          }
        ]
      }
    }
  ],
  "timeoutMs": 60000
}
