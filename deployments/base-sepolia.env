# Non-secret env vars for Base Sepolia testnet
# Auto-populated by: npx hardhat run scripts/deploy.js --network base-sepolia
# After deploying, commit this file to share addresses with other services.
#
# After editing this file, regenerate render.yaml:
#   node scripts/generate-render-yaml.mjs

UI_PUBLIC_ROOT_DOMAIN=commonality.works
UI_PUBLIC_ENVIRONMENT_LABEL=testnet
UI_PUBLIC_URL_SCHEME=https
UI_CORS_EXTRA_ROOT_DOMAINS=

EVENT_CACHE_URL=https://commonality-indexer.onrender.com
PLATFORM_API_URL=https://commonality-platform-api.onrender.com
BASE_SEPOLIA_PAYMASTER_URL=https://commonality-platform-api.onrender.com/sponsored-gas/paymaster
CONTENT_FINDER_PLATFORM_API_URL=https://commonality-platform-api.onrender.com
CONTENT_FINDER_SUBMISSIONS_API_URL=https://commonality-platform-api.onrender.com/content-submission
CONTENT_FINDER_ATTESTER_URL=https://commonality-service-host-attesters.onrender.com/content-attester
IMPLICATION_FINDER_ATTESTER_URL=https://commonality-service-host-attesters.onrender.com/implication-attester

VITE_ENABLE_CHANNEL_METADATA_LOOKUP=true

# Beat-memory + beat-agent rehearsal policy for US politics. Most of this is
# generated by scripts/setup-testnet-ai-policy.mjs; X_API_BEARER_TOKEN is still manual.
BEAT_MEMORY_ENABLED=true
BEAT_MEMORY_BEAT_ID=us-politics
BEAT_MEMORY_PURPOSES=civility_context,general_beat_context,source_management
BEAT_MEMORY_BEAT_DEFINITION_JSON={"beatId":"us-politics","purposes":["civility_context"],"sources":[]}
BEAT_MEMORY_INGESTION_STATE_FILE=/data/beat-memory/us-politics.ingestion.json
BEAT_MEMORY_MEMORY_FILE=/data/beat-memory/us-politics.memory.json
BEAT_MEMORY_METRICS_LOG_FILE=/data/beat-memory/us-politics.metrics.jsonl
BEAT_MEMORY_WORKER_POLL_INTERVAL_MS=300000
BEAT_MEMORY_LLM_EXTRACTION_ENABLED=true
BEAT_AGENT_ENABLED=true
BEAT_AGENT_BEAT_ID=us-politics
BEAT_AGENT_NAME=us-politics-civility
BEAT_AGENT_PROMPT_TEMPLATE=Evaluate US-politics content: {content}
BEAT_AGENT_INGESTION_STATE_FILE=/data/beat-memory/us-politics.ingestion.json
BEAT_AGENT_MEMORY_FILE=/data/beat-memory/us-politics.memory.json
BEAT_AGENT_EVALUATION_LOG_FILE=/data/beat-agent/us-politics.evaluations.jsonl
BEAT_AGENT_METRICS_LOG_FILE=/data/beat-agent/us-politics.metrics.jsonl
BEAT_AGENT_FINDER_ENABLED=false
BEAT_AGENT_FINDER_STATE_FILE=/data/beat-agent/us-politics.finder.json
BEAT_AGENT_FINDER_ATTESTER_URL=https://commonality-service-host-attesters.onrender.com/beat-agent/evaluate-content
BEAT_AGENT_BEAT_KEYWORDS=politics,policy,democrat,republican,liberal,conservative,bipartisan,civility,persuasion,good faith,common ground
BEAT_AGENT_PLATFORM_API_URL=https://commonality-platform-api.onrender.com
BEAT_AGENT_MINIMUM_CONFIDENCE=medium
BEAT_AGENT_ESTIMATED_INPUT_TOKENS=5000
BEAT_AGENT_ESTIMATED_OUTPUT_TOKENS=700

CONTENT_ATTESTER_NAME=noninflammatory-neutral
# Or use CONTENT_ATTESTER_PROMPT_TEMPLATE_FILE for local/container runs.
# Prompt placeholders use single braces: {content}, {declared_perspective_context}
CONTENT_ATTESTER_PROMPT_TEMPLATE=Evaluate whether this content supports the configured topic: {content}

