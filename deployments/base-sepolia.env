# Non-secret env vars for Base Sepolia testnet
# Auto-populated by: npx hardhat run scripts/deploy.js --network base-sepolia
# After deploying, commit this file to share addresses with other services.
#
# After editing this file, regenerate render.yaml:
#   node scripts/generate-render-yaml.mjs

