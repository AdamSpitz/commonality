{
  "name": "commonality",
  "version": "1.0.0",
  "description": "Commonality - Coordinated crowdfunding with composable delegation",
  "private": true,
  "type": "module",
  "workspaces": [
    "sdk",
    "integration-tests",
    "hardhat",
    "indexer",
    "attester-core",
    "finder-core",
    "implication-attester",
    "content-attester",
    "beat-agent",
    "implication-finder",
    "content-finder",
    "service-host",
    "platform-api-service",
    "fake-data-generation",
    "nudger-core",
    "implication-graph-nudger",
    "bridge-creator",
    "explorer-curator",
    "ui"
  ],
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "npm@11.6.2",
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint-precommit": "npm run lint --workspace hardhat && npm run lint --workspace indexer && npm run lint --workspace sdk",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "build": "turbo run build",
    "build:docs": "turbo run docs --filter=@commonality/sdk --filter=@commonality/hardhat",
    "attester:build": "turbo run build --filter=@commonality/implication-attester",
    "ui:dev": "npm run dev --workspace=ui",
    "ui:dev:commonality": "npm run dev:commonality --workspace=ui",
    "ui:dev:lazyGiving": "npm run dev:lazyGiving --workspace=ui",
    "ui:dev:alignment": "npm run dev:alignment --workspace=ui",
    "ui:dev:tally": "npm run dev:tally --workspace=ui",
    "ui:dev:content-funding": "npm run dev:content-funding --workspace=ui",
    "ui:dev:civility": "npm run dev:civility --workspace=ui",
    "ui:dev:common-sense-majority": "npm run dev:common-sense-majority --workspace=ui",
    "ui:dev:conceptspace": "npm run dev:conceptspace --workspace=ui",
    "ui:build": "turbo run build --filter=ui",
    "ui:build:domains": "turbo run build:domains --filter=ui",
    "ui:build:ipfs": "turbo run build:ipfs --filter=ui",
    "ui:build:ipfs:domains": "turbo run build:ipfs:domains --filter=ui",
    "deploy:testnet:uber-ui": "./scripts/deploy-testnet-uber-ui.sh",
    "test": "npm run sdk:test && npm run hardhat:test && npm run integration-tests && npm run ui:test",
    "test:fast": "npm run check:docs-inventory && npm run sdk:test && npm run hardhat:test && npm run integration-tests:test:harness && npm run ui:test:vitest",
    "deploy-local": "cd hardhat && npx hardhat run scripts/deploy-local.js --network localhost",
    "integration-tests": "./scripts/run-integration-tests.sh",
    "integration-tests:typecheck": "npm run --workspace=integration-tests typecheck",
    "integration-tests:test:harness": "npm run test:harness --workspace=integration-tests",
    "integration-tests:verbose": "VERBOSE_TESTS=true ./scripts/run-integration-tests.sh",
    "sdk:test": "npm run test --workspace=sdk",
    "ui:test": "npm run test --workspace=ui",
    "ui:test:vitest": "npm run test:vitest --workspace=ui",
    "ui:test:e2e": "npm run test:e2e --workspace=ui",
    "hardhat:node": "npx --workspace=hardhat hardhat node",
    "hardhat:compile": "npx --workspace=hardhat hardhat compile",
    "hardhat:test": "npx --workspace=hardhat hardhat test",
    "indexer:typecheck": "npx --workspace=indexer tsc",
    "smoke-check": "node scripts/smoke-check-render.mjs",
    "cloudflare-gateway:test": "node cloudflare-service-gateway/service-gateway.test.mjs && node cloudflare-ui-gateway/ui-gateway.test.mjs",
    "check:docs-links": "./scripts/check-docs-links.sh",
    "verifier:report": "node scripts/verifier-report.mjs",
    "verifier:root": "verifier-run root",
    "verifier:fast": "node scripts/verifier-fast-fresh.mjs",
    "verifier:fast:rollup": "verifier-run validation.pr",
    "verifier:pr": "npm run verifier:fast",
    "verifier:pr:rollup": "npm run verifier:fast:rollup",
    "verifier:functionality": "verifier-run facet.functionality",
    "verifier:testnet": "verifier-run testnet.environment",
    "verifier:docs": "verifier-run facet.docs",
    "verifier:product": "verifier-run facet.product",
    "verifier:security": "verifier-run facet.security",
    "verifier:state": "verifier-run root",
    "verifier:status": "npm run verifier:fast && npm run verifier:root",
    "verifier:currency": "verifier-run meta.report-currency",
    "verifier:run": "verifier-scheduler",
    "verifier:heartbeat": "verifier-heartbeat",
    "verifier:summarize": "verifier-summarize",
    "verifier:go": "node scripts/verifier-go.mjs",
    "verifier:tree": "verifier-tree root",
    "prepare": "husky",
    "check:docs-inventory": "node scripts/check-docs-inventory.mjs"
  },
  "keywords": [
    "blockchain",
    "crowdfunding",
    "delegation",
    "ethereum"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@adamspitz/verifier": "^0.1.1",
    "husky": "^9.1.7",
    "markdown-link-check": "^3.14.2",
    "turbo": "^2.5.8",
    "vite": "7.2.4"
  },
  "overrides": {
    "viem": "2.47.6",
    "rollup": "4.59.0"
  },
  "dependencies": {
    "w3name": "^1.1.3"
  }
}
