{
  "name": "commonality",
  "version": "1.0.0",
  "description": "Commonality - Coordinated crowdfunding with composable delegation",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "workspaces": [
    "sdk",
    "integration-tests",
    "hardhat",
    "indexer"
  ],
  "scripts": {
    "test": "pnpm run hardhat:test && pnpm run integration-tests",
    "deploy-local": "pnpm --filter hardhat exec hardhat run scripts/deploy-local.js --network localhost",
    "integration-tests": "./scripts/run-integration-tests.sh",
    "integration-tests:verbose": "VERBOSE_TESTS=true ./scripts/run-integration-tests.sh",
    "hardhat:node": "pnpm --filter hardhat exec hardhat node",
    "hardhat:compile": "pnpm --filter hardhat exec hardhat compile",
    "hardhat:test": "pnpm --filter hardhat exec hardhat test"
  },
  "keywords": ["blockchain", "crowdfunding", "delegation", "ethereum"],
  "author": "",
  "license": "MIT"
}
