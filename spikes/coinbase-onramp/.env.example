# Coinbase Developer Platform (CDP) *Secret* API key — used to generate the
# Onramp session token. Create at https://portal.cdp.coinbase.com → your project
# → API keys → "Create Secret API key". Download gives you these two values.
#
# Copy this file to `.env` and fill them in.

# The key id / name (a UUID or "organizations/.../apiKeys/..." string).
CDP_API_KEY_ID=

# The private key. For an Ed25519 key this is a base64 string; for an EC (ES256)
# key it's a PEM block. Paste it as-is. If it's a multi-line PEM, wrap it in
# double quotes and keep the literal \n or real newlines.
CDP_API_KEY_SECRET=

# Optional: your public IP. Coinbase wants the *end user's* IP for the session
# token. For a local spike this is you; leave blank and the script will fetch it.
CLIENT_IP=
