{
  "name": "@commonality/attester-host",
  "version": "0.1.0",
  "description": "Host process for bundling the implication and content attesters under one Express app",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "npm run build --workspace=@commonality/implication-attester && npm run build --workspace=@commonality/content-attester",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "mocha",
    "lint": "eslint ."
  },
  "dependencies": {
    "@commonality/content-attester": "0.1.0",
    "@commonality/implication-attester": "0.1.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "mocha": "^10.8.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.46.4"
  }
}
